---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import { SITE } from "@/config";
import { BUDDHIST_EVENTS, BUDDHIST_RULES } from "@/data/buddhist-calendar/events";
---

<Layout title={`佛历 | ${SITE.title}`} description="查看当前日期对应的佛历事件（按农历月-日匹配）。">
  <Header />
  <Main pageTitle="佛历" pageDesc="查看今天（或任意日期）的佛历事件123。">
    <section class="rounded-xl border border-border bg-(--bg-card) p-4 sm:p-5">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <div class="text-sm text-foreground/70">选择日期</div>
          <input
            id="foli-date"
            type="date"
            class="mt-1 w-full rounded-lg border border-border bg-background px-3 py-2 text-sm outline-none focus:border-accent sm:w-auto"
          />
        </div>

        <div class="text-sm text-foreground/70">
          <div>
            公历：
            <span id="foli-human-date" class="font-medium text-foreground"></span>
          </div>
          <div class="mt-1">
            农历：
            <span id="foli-lunar-date" class="font-medium text-foreground"></span>
          </div>
        </div>
      </div>

      <div class="mt-4 border-t border-border pt-4">
        <div id="foli-empty" class="hidden text-sm text-foreground/70">
          这一天暂无已收录的佛历事件。
        </div>
        <ul id="foli-events" class="grid grid-cols-1 gap-3"></ul>
      </div>
    </section>

    <details class="mt-6 rounded-xl border border-border bg-(--bg-card) p-4 sm:p-5">
      <summary class="cursor-pointer select-none text-sm font-medium">
        提示
      </summary>
      <div class="mt-3 text-sm text-foreground/80">
        佛历纪念日的口径在不同寺院/传统中可能略有差异，本页内容仅供参考。
        如发现错误或希望补充，请在
        <a class="underline decoration-border hover:text-accent" href="/about">关于</a>
        页面联系作者。
      </div>
    </details>

    <details class="mt-4 rounded-xl border border-border bg-(--bg-card) p-4 sm:p-5">
      <summary class="cursor-pointer select-none text-sm font-medium">
        全年佛历（按有事件的日期列出）
      </summary>
      <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <div class="text-sm text-foreground/70">选择年份</div>
          <input
            id="foli-year"
            type="number"
            inputmode="numeric"
            class="mt-1 w-full rounded-lg border border-border bg-background px-3 py-2 text-sm outline-none focus:border-accent sm:w-40"
            min="1900"
            max="2100"
          />
        </div>
        <div class="text-sm text-foreground/70">
          仅列出“有事件”的日期（含朔望、六斋日、十斋日与纪念日）。
        </div>
      </div>

      <div class="mt-4 border-t border-border pt-4">
        <div id="foli-year-empty" class="hidden text-sm text-foreground/70">
          该年份暂无可显示的数据。
        </div>
        <div id="foli-year-list" class="grid grid-cols-1 gap-4"></div>
      </div>
    </details>
  </Main>
  <Footer />
</Layout>

<script is:inline define:vars={{ EVENTS: BUDDHIST_EVENTS, RULES: BUDDHIST_RULES }}>
  // Expose data for the module script.
  // `define:vars` variables are scoped to this script, so we attach them to `window`.
  window.__FOLI__ = { EVENTS, RULES };
</script>
<script src="../scripts/foli.ts"></script>

